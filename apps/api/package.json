    "@pipelineflow-engagement/shared": "workspace:*",
    "@prisma/client": "^5.22.0",
    "argon2": "^0.41.1",
    "bullmq": "^5.34.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.0.0",
    "html-to-text": "^9.0.5",
    "ioredis": "^5.4.1",
