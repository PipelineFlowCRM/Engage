# API-only env. For docker-compose, the root .env feeds these via env_file.
NODE_ENV=development
PORT=4100
DATABASE_URL=postgresql://pfengagement:pfengagement@localhost:5440/pfengagement
REDIS_URL=redis://localhost:6381
APP_ORIGIN=http://localhost:5174

# Crypto. Both REQUIRED in production.
# openssl rand -base64 32
SECRET_ENCRYPTION_KEY=
# openssl rand -base64 64
PREFERENCES_JWT_KEY=

# CRM bridge (optional)
CRM_BASE_URL=
CRM_SHARED_SECRET=

# Optional flags
SESSION_COOKIE_SECURE=
BULL_BOARD_ENABLED=true
JOBS_TEST_ENDPOINT_ENABLED=false

# Rate limits
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_WINDOW_MS=300000

# Event partitioning (Timescale)
EVENT_RETENTION_DAYS=365
EVENT_COMPRESSION_AFTER_DAYS=7
