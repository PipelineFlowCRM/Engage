# Root-level shared environment for `docker compose up`.
# Copy to .env and fill in real values before running.

# ── Database (TimescaleDB) ────────────────────────────────────────────────────
POSTGRES_USER=pfengagement
POSTGRES_PASSWORD=pfengagement
POSTGRES_DB=pfengagement
# Default port shifted off 5432/5439 (CRM uses 5439) so both can co-exist.
POSTGRES_PORT=5440

# ── API ───────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://pfengagement:pfengagement@postgres:5432/pfengagement
APP_ORIGIN=http://localhost:5174

# ── Redis / job queue ─────────────────────────────────────────────────────────
# CRM uses 6380; we use 6381.
REDIS_PORT=6381
REDIS_PASSWORD=
REDIS_MAXMEMORY=256mb
WORKER_CONCURRENCY=5
BULL_BOARD_ENABLED=true
JOBS_TEST_ENDPOINT_ENABLED=false

# ── Networking ────────────────────────────────────────────────────────────────
# Default-deny: bind to 127.0.0.1; flip to 0.0.0.0 only behind a TLS proxy.
BIND_HOST=127.0.0.1
API_PORT=4100
WEB_PORT=5174

# ── Backups ───────────────────────────────────────────────────────────────────
BACKUP_RETAIN_DAYS=30
BACKUP_DEBOUNCE_SEC=300

# ── Event retention (Timescale) ───────────────────────────────────────────────
# Drop chunks older than this many days. Default 365 = 1 year.
EVENT_RETENTION_DAYS=365
# Compress chunks older than this many days. Compressed chunks are read-only;
# late-arriving events with receivedAt inside a compressed chunk will fail
# unless decompressed. Set wider than your max event lateness.
EVENT_COMPRESSION_AFTER_DAYS=7

# ── AWS SES ───────────────────────────────────────────────────────────────────
# Region + IAM creds live in the encrypted Secret table once set via the UI.
# These two only kick in if you want to bootstrap via env on first boot.
SES_BOOTSTRAP_REGION=
SES_BOOTSTRAP_ACCESS_KEY_ID=
SES_BOOTSTRAP_SECRET_ACCESS_KEY=

# ── Crypto ────────────────────────────────────────────────────────────────────
# AES-256-GCM key for the Secret table. Must be exactly 32 bytes after
# base64-decoding. Generate with: openssl rand -base64 32
SECRET_ENCRYPTION_KEY=
# HS256 key for preferences-center JWTs (1y-lived per-subscriber tokens).
# Generate with: openssl rand -base64 64
PREFERENCES_JWT_KEY=

# ── PipelineFlow CRM integration (optional) ───────────────────────────────────
# Unset → CRM features disabled; standalone mode.
CRM_BASE_URL=
# HMAC secret shared with the CRM for both inbound webhooks and SSO JWTs.
# Generate with: openssl rand -base64 64
CRM_SHARED_SECRET=
